POSTGRES_DB=stocket
POSTGRES_USER=stocket
POSTGRES_PASSWORD=replace-with-a-long-random-local-password
POSTGRES_PASSWORD_FILE=../secrets/postgres-password.txt
STOCKET_PORT=8088
# 生产必须为公开 HTTPS Origin，例如 https://stocket.example.com
STOCKET_FRONTEND_URL=https://stocket.example.com
STOCKET_MASTER_KEY_FILE=../secrets/master-key.txt
STOCKET_TLS_CERT_FILE=../secrets/tls.crt
STOCKET_TLS_KEY_FILE=../secrets/tls.key
STOCKET_VERSION=dev
STOCKET_TRUSTED_PROXY_CIDRS=172.16.0.0/12
# 可选官方备用源：container-registry.oracle.com/graalvm/native-image:25
GRAALVM_IMAGE=ghcr.io/graalvm/native-image-community:25
